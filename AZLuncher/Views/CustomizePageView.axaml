<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AZLuncher.ViewModels"
             x:Class="AZLuncher.Views.CustomizePageView"
             x:DataType="vm:CustomizePageViewModel">

    <Grid RowDefinitions="Auto,Auto" RowSpacing="20">
        <Border Classes="surfaceCard" Padding="{DynamicResource CardInnerPadding}">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                <StackPanel Spacing="20">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="sectionEyebrow" Text="{Binding SectionLabel}" />
                        <TextBlock FontSize="32" FontWeight="Black" Text="{Binding SectionHeading}" />
                        <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                   Text="{Binding SectionSummary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock Classes="sectionEyebrow" Text="{Binding ThemeGroupLabel}" />

                        <Border Classes="softCard" Padding="18">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding MossTitle}" />
                                <Border Grid.Column="1" Classes="pill" Padding="10,5" IsVisible="{Binding IsMossSelected}">
                                    <TextBlock Text="{Binding ActiveLabel}" />
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding MossSummary}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Classes="secondaryButton"
                                        Command="{Binding UseMossThemeCommand}"
                                        Content="{Binding MossTitle}" />
                            </Grid>
                        </Border>

                        <Border Classes="softCard" Padding="18">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding MidnightTitle}" />
                                <Border Grid.Column="1" Classes="pill" Padding="10,5" IsVisible="{Binding IsMidnightSelected}">
                                    <TextBlock Text="{Binding ActiveLabel}" />
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding MidnightSummary}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Classes="secondaryButton"
                                        Command="{Binding UseMidnightThemeCommand}"
                                        Content="{Binding MidnightTitle}" />
                            </Grid>
                        </Border>

                        <Border Classes="softCard" Padding="18">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding EmberTitle}" />
                                <Border Grid.Column="1" Classes="pill" Padding="10,5" IsVisible="{Binding IsEmberSelected}">
                                    <TextBlock Text="{Binding ActiveLabel}" />
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding EmberSummary}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Classes="secondaryButton"
                                        Command="{Binding UseEmberThemeCommand}"
                                        Content="{Binding EmberTitle}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="20">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="sectionEyebrow" Text="{Binding BrandingGroupLabel}" />

                        <Border Classes="softCard" Padding="18">
                            <StackPanel Spacing="10">
                                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding BrandingTitle}" />
                                <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding BrandingSummary}"
                                           TextWrapping="Wrap" />
                                <TextBox Classes="configTextBox"
                                         Text="{Binding LauncherTitle}"
                                         Watermark="AZLauncher" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock Classes="sectionEyebrow" Text="{Binding DensityGroupLabel}" />

                        <Border Classes="softCard" Padding="18">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding ComfortableTitle}" />
                                <Border Grid.Column="1" Classes="pill" Padding="10,5" IsVisible="{Binding IsComfortableSelected}">
                                    <TextBlock Text="{Binding ActiveLabel}" />
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding ComfortableSummary}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Classes="secondaryButton"
                                        Command="{Binding UseComfortableDensityCommand}"
                                        Content="{Binding ComfortableTitle}" />
                            </Grid>
                        </Border>

                        <Border Classes="softCard" Padding="18">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding CompactTitle}" />
                                <Border Grid.Column="1" Classes="pill" Padding="10,5" IsVisible="{Binding IsCompactSelected}">
                                    <TextBlock Text="{Binding ActiveLabel}" />
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding CompactSummary}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Classes="secondaryButton"
                                        Command="{Binding UseCompactDensityCommand}"
                                        Content="{Binding CompactTitle}" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock Classes="sectionEyebrow" Text="{Binding ShapeGroupLabel}" />

                        <Border Classes="softCard" Padding="18">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding RoundedTitle}" />
                                <Border Grid.Column="1" Classes="pill" Padding="10,5" IsVisible="{Binding IsRoundedSelected}">
                                    <TextBlock Text="{Binding ActiveLabel}" />
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding RoundedSummary}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Classes="secondaryButton"
                                        Command="{Binding UseRoundedShapeCommand}"
                                        Content="{Binding RoundedTitle}" />
                            </Grid>
                        </Border>

                        <Border Classes="softCard" Padding="18">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="12">
                                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding DefinedTitle}" />
                                <Border Grid.Column="1" Classes="pill" Padding="10,5" IsVisible="{Binding IsDefinedSelected}">
                                    <TextBlock Text="{Binding ActiveLabel}" />
                                </Border>
                                <TextBlock Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding DefinedSummary}"
                                           TextWrapping="Wrap" />
                                <Button Grid.Row="2"
                                        Grid.ColumnSpan="2"
                                        Classes="secondaryButton"
                                        Command="{Binding UseDefinedShapeCommand}"
                                        Content="{Binding DefinedTitle}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="surfaceCard" Padding="{DynamicResource CardInnerPadding}">
            <Grid ColumnDefinitions="320,*" ColumnSpacing="20">
                <StackPanel Spacing="12">
                    <TextBlock Classes="sectionEyebrow" Text="{Binding PreviewTitle}" />
                    <TextBlock FontSize="28" FontWeight="Black" Text="{Binding PreviewHeroTitle}" />
                    <TextBlock Foreground="{StaticResource MutedInkBrush}"
                               Text="{Binding PreviewSummary}"
                               TextWrapping="Wrap" />

                    <Border Classes="softCard" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="Bold" Text="{Binding CurrentTitleLabel}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}" Text="{Binding LauncherTitle}" />
                            <TextBlock FontWeight="Bold" Margin="0,8,0,0" Text="{Binding ConfigPathLabel}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       Text="{Binding ConfigPath}"
                                       TextWrapping="Wrap" />
                            <TextBlock FontWeight="Bold" Text="{Binding CurrentThemeLabel}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}" Text="{Binding CurrentThemeName}" />
                            <TextBlock FontWeight="Bold" Margin="0,8,0,0" Text="{Binding CurrentDensityLabel}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}" Text="{Binding CurrentDensityName}" />
                            <TextBlock FontWeight="Bold" Margin="0,8,0,0" Text="{Binding CurrentShapeLabel}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}" Text="{Binding CurrentShapeName}" />
                        </StackPanel>
                    </Border>

                    <Button Classes="secondaryButton"
                            Command="{Binding ResetAppearanceCommand}"
                            Content="{Binding ResetLabel}" />
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource HeroBrush}" CornerRadius="{DynamicResource SurfaceCardRadius}" Padding="28">
                    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="16">
                        <Border Classes="pill" Padding="12,6" HorizontalAlignment="Left">
                            <TextBlock Foreground="{StaticResource SidebarTextBrush}" Text="{Binding PreviewEyebrow}" />
                        </Border>

                        <StackPanel Grid.Row="1" Spacing="8">
                            <TextBlock FontSize="36"
                                       FontWeight="Black"
                                       Foreground="#FFFFF8ED"
                                       Text="{Binding LauncherTitle}" />
                            <TextBlock MaxWidth="520"
                                       Foreground="#F0F6ECDE"
                                       Text="{Binding PreviewHeroSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid Grid.Row="3" ColumnDefinitions="Auto,Auto" ColumnSpacing="12">
                            <Button Classes="launchButton" Content="{Binding PreviewPrimaryAction}" />
                            <Button Grid.Column="1" Classes="secondaryButton" Content="{Binding PreviewSecondaryAction}" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
