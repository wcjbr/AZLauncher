<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AZLuncher.ViewModels"
             xmlns:model="using:AZLuncher.Models"
             x:Class="AZLuncher.Views.LibraryPageView"
             x:DataType="vm:LibraryPageViewModel">

    <Grid RowDefinitions="Auto,Auto" RowSpacing="20">
        <Border Classes="surfaceCard" Padding="28">
            <Grid ColumnDefinitions="*,320" ColumnSpacing="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="sectionEyebrow" Text="{Binding SectionLabel}" />
                    <TextBlock FontSize="32" FontWeight="Black" Text="{Binding SectionHeading}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="12">
                    <Border Classes="softCard" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="Bold" Text="{Binding SummaryTitle}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       Text="{Binding SummaryBody}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Classes="softCard" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="Bold" Text="{Binding ToolchainTitle}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       Text="{Binding ToolchainBody}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="surfaceCard" Padding="28">
            <StackPanel Spacing="18">
                <StackPanel Spacing="8">
                    <TextBlock Classes="sectionEyebrow" Text="{Binding TabsLabel}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Classes="tabButton" Command="{Binding ShowModsCommand}" Content="{Binding ModsTabLabel}" />
                        <Button Classes="tabButton" Command="{Binding ShowResourcePacksCommand}" Content="{Binding ResourcePacksTabLabel}" />
                        <Button Classes="tabButton" Command="{Binding ShowShadersCommand}" Content="{Binding ShadersTabLabel}" />
                    </StackPanel>
                </StackPanel>

                <Border Classes="softCard" Padding="18">
                    <StackPanel Spacing="8">
                        <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding ActiveTabLabel}" />
                        <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                   Text="{Binding ActiveTabSummary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding VisibleLibraryItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="model:LibraryItem">
                            <Border Classes="softCard" Margin="0,0,0,14" Padding="18">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="12">
                                    <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Name}" />
                                    <Border Grid.Column="1"
                                            Classes="pill"
                                            HorizontalAlignment="Right"
                                            Padding="10,5"
                                            Background="#1C50783C"
                                            BorderBrush="#2250783C">
                                        <TextBlock Foreground="{StaticResource AccentDeepBrush}" Text="{Binding State}" />
                                    </Border>
                                    <TextBlock Grid.Row="1" Foreground="{StaticResource MutedInkBrush}" Text="{Binding Category}" />
                                    <TextBlock Grid.Row="2"
                                               MaxWidth="760"
                                               Foreground="{StaticResource MutedInkBrush}"
                                               Text="{Binding Summary}"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
