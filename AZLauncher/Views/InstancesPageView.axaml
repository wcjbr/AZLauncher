<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AZLauncher.ViewModels"
             xmlns:model="using:AZLauncher.Models"
             x:Class="AZLauncher.Views.InstancesPageView"
             x:DataType="vm:InstancesPageViewModel">

    <Grid RowDefinitions="Auto,Auto" RowSpacing="20">
        <Border Classes="surfaceCard" Padding="28">
            <Grid ColumnDefinitions="*,320" ColumnSpacing="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="sectionEyebrow" Text="{Binding SectionLabel}" />
                    <TextBlock FontSize="32" FontWeight="Black" Text="{Binding SectionHeading}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="12">
                    <Border Classes="softCard" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="Bold" Text="{Binding RuntimeCardTitle}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       Text="{Binding RuntimeSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Classes="softCard" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="Bold" Text="{Binding QueueCardTitle}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       Text="{Binding ActiveQueueSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="surfaceCard" Padding="28">
            <ItemsControl ItemsSource="{Binding InstalledVersions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="model:LauncherVersion">
                        <Border Classes="softCard" Margin="0,0,0,14" Padding="18">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="12">
                                <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding Name}" />
                                <Border Grid.Column="1"
                                        Classes="pill"
                                        HorizontalAlignment="Right"
                                        Padding="10,5"
                                        Background="#1C50783C"
                                        BorderBrush="#2250783C"
                                        IsVisible="{Binding HasBadge}">
                                    <TextBlock Foreground="{StaticResource AccentDeepBrush}" Text="{Binding BadgeText}" />
                                </Border>
                                <TextBlock Grid.Row="1" Foreground="{StaticResource MutedInkBrush}" Text="{Binding Channel}" />
                                <TextBlock Grid.Row="2"
                                           MaxWidth="720"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding Summary}"
                                           TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Bottom"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding LastPlayed}" />
                                <Button Grid.Row="3"
                                        Grid.ColumnSpan="2"
                                        HorizontalAlignment="Left"
                                        Classes="secondaryButton"
                                        Command="{Binding $parent[vm:InstancesPageViewModel].ActivateVersionCommand}"
                                        CommandParameter="{Binding Id}"
                                        Content="{Binding $parent[vm:InstancesPageViewModel].SetActiveLabel}"
                                        IsVisible="{Binding !IsActive}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</UserControl>
