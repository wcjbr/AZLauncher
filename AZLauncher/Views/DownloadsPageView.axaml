<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AZLauncher.ViewModels"
             xmlns:models="using:AZLauncher.Models"
             x:Class="AZLauncher.Views.DownloadsPageView"
             x:Name="Root"
             x:DataType="vm:DownloadsPageViewModel">

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="20">
        <Border Classes="surfaceCard" Padding="{DynamicResource CardInnerPadding}">
            <StackPanel Spacing="8">
                <TextBlock Classes="sectionEyebrow" Text="{Binding SectionLabel}" />
                <TextBlock FontSize="32" FontWeight="Black" Text="{Binding SectionHeading}" />
                <TextBlock MaxWidth="860"
                           Foreground="{StaticResource MutedInkBrush}"
                           Text="{Binding SectionSummary}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="surfaceCard" Padding="{DynamicResource CardInnerPadding}">
            <StackPanel Spacing="12">
                <TextBlock Classes="sectionEyebrow" Text="{Binding TabsLabel}" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Classes="tabButton" Command="{Binding ShowGamesCommand}" Content="{Binding GamesTabLabel}" />
                    <Button Classes="tabButton" Command="{Binding ShowLoadersCommand}" Content="{Binding LoadersTabLabel}" />
                    <Button Classes="tabButton" Command="{Binding ShowResourcesCommand}" Content="{Binding ResourcesTabLabel}" />
                </StackPanel>
                <TextBlock FontSize="24" FontWeight="Bold" Text="{Binding ActiveSectionTitle}" />
                <TextBlock Foreground="{StaticResource MutedInkBrush}"
                           Text="{Binding ActiveSectionSummary}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid ColumnDefinitions="*,320" ColumnSpacing="20" Margin="0,0,0,24">
                <StackPanel Spacing="20">
                    <Border Classes="surfaceCard"
                            Padding="{DynamicResource CardInnerPadding}"
                            IsVisible="{Binding IsGamesSelected}">
                        <StackPanel Spacing="18">
                            <TextBlock Classes="sectionEyebrow" Text="{Binding GamesTabLabel}" />
                            <Grid ColumnDefinitions="220,220,Auto,Auto" ColumnSpacing="10">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding SourceLabel}" />
                                    <ComboBox Classes="languagePicker"
                                              ItemsSource="{Binding Sources}"
                                              SelectedItem="{Binding SelectedGameSource}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="{Binding InstanceLabel}" />
                                    <ComboBox Classes="languagePicker"
                                              ItemsSource="{Binding AvailableInstances}"
                                              SelectedItem="{Binding SelectedInstance}" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Classes="secondaryButton"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding RefreshGameVersionsCommand}"
                                        Content="{Binding RefreshLabel}" />
                                <Button Grid.Column="3"
                                        Classes="secondaryButton"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding OpenGameInstallPanelCommand}"
                                        Content="{Binding OpenInstallPanelLabel}" />
                            </Grid>

                            <Border Classes="softCard" Padding="18">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="sectionEyebrow" Text="{Binding CurrentVersionSummaryLabel}" />
                                    <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding CurrentInstanceVersionSummary}" />
                                    <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                               Text="{Binding CurrentTargetPath}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <StackPanel Spacing="10">
                                <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding GameVersionLabel}" />
                                <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                           Text="{Binding ActiveSectionSummary}"
                                           TextWrapping="Wrap" />
                                <ListBox SelectedItem="{Binding SelectedGameVersion}"
                                         ItemsSource="{Binding AvailableGameVersions}"
                                         MinHeight="144"
                                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="12" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="models:DownloadableGameVersion">
                                            <Border Classes="softCard" Width="190" Padding="16">
                                                <StackPanel Spacing="6">
                                                    <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding Id}" />
                                                    <TextBlock Foreground="{StaticResource MutedInkBrush}" Text="{Binding Type}" />
                                                    <TextBlock Foreground="{StaticResource MutedInkBrush}" Text="{Binding ReleaseTime}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="surfaceCard"
                            Padding="{DynamicResource CardInnerPadding}"
                            IsVisible="{Binding IsLoadersSelected}">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="sectionEyebrow" Text="{Binding LoadersTabLabel}" />
                            <Grid ColumnDefinitions="180,180,*,Auto,Auto" ColumnSpacing="10">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding SourceLabel}" />
                                    <ComboBox Classes="languagePicker"
                                              ItemsSource="{Binding Sources}"
                                              SelectedItem="{Binding SelectedLoaderSource}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="{Binding LoaderKindLabel}" />
                                    <ComboBox Classes="languagePicker"
                                              ItemsSource="{Binding LoaderKinds}"
                                              SelectedItem="{Binding SelectedLoaderKind}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="{Binding LoaderVersionLabel}" />
                                    <ComboBox Classes="languagePicker"
                                              ItemsSource="{Binding AvailableLoaderVersions}"
                                              SelectedItem="{Binding SelectedLoaderVersion}" />
                                </StackPanel>
                                <Button Grid.Column="3"
                                        Classes="secondaryButton"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding RefreshLoaderVersionsCommand}"
                                        Content="{Binding RefreshLabel}" />
                                <Button Grid.Column="4"
                                        Classes="secondaryButton"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding DownloadLoaderCommand}"
                                        Content="{Binding DownloadLoaderLabel}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="surfaceCard"
                            Padding="{DynamicResource CardInnerPadding}"
                            IsVisible="{Binding IsResourcesSelected}">
                        <StackPanel Spacing="18">
                            <TextBlock Classes="sectionEyebrow" Text="{Binding ResourcesTabLabel}" />
                            <Grid ColumnDefinitions="180,*,Auto" ColumnSpacing="10">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding ResourceKindLabel}" />
                                    <ComboBox Classes="languagePicker"
                                              ItemsSource="{Binding ResourceKinds}"
                                              SelectedItem="{Binding SelectedResourceKind}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="{Binding ResourceSearchLabel}" />
                                    <TextBox Classes="configTextBox"
                                             Text="{Binding ResourceSearchQuery}"
                                             Watermark="{Binding ResourceSearchHint}" />
                                </StackPanel>
                                <Button Grid.Column="2"
                                        Classes="secondaryButton"
                                        VerticalAlignment="Bottom"
                                        Command="{Binding SearchResourcesCommand}"
                                        Content="{Binding SearchResourceLabel}" />
                            </Grid>

                            <Border Classes="softCard" Padding="18">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="sectionEyebrow" Text="{Binding SearchResultsLabel}" />
                                    <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding ResourceProviderSummary}" />
                                    <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                               Text="{Binding ResourceContextSummary}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                               Text="{Binding ResourceStatusMessage}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <Border Classes="softCard" Padding="18">
                                    <StackPanel Spacing="12">
                                        <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding SearchResultsLabel}" />
                                        <ScrollViewer Height="360"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding SearchResults}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SearchableResourceResult">
                                                        <Border Classes="surfaceCard" Padding="16" Margin="0,0,0,12">
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                                <StackPanel Spacing="6">
                                                                    <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding Title}" />
                                                                    <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                                                               Text="{Binding Author, StringFormat='by {0}'}" />
                                                                    <TextBlock Foreground="{StaticResource MutedInkBrush}" Text="{Binding VersionLabel}" />
                                                                    <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                                <Button Grid.Column="1"
                                                                        Classes="secondaryButton"
                                                                        VerticalAlignment="Top"
                                                                        Command="{ReflectionBinding #Root.DataContext.InstallSearchResultCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="{ReflectionBinding #Root.DataContext.InstallResourceLabel}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Classes="softCard" Padding="18">
                                    <StackPanel Spacing="12">
                                        <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding LocalResourcesLabel}" />
                                        <ScrollViewer Height="360"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding LocalResources}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:LocalResourceFileItem">
                                                        <Border Classes="surfaceCard" Padding="16" Margin="0,0,0,12">
                                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                                <StackPanel Spacing="6">
                                                                    <TextBlock FontSize="18" FontWeight="Bold" Text="{Binding DisplayName}" />
                                                                    <TextBlock Foreground="{StaticResource MutedInkBrush}" Text="{Binding FileName}" />
                                                                    <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                                <Button Grid.Column="1"
                                                                        Classes="secondaryButton"
                                                                        VerticalAlignment="Top"
                                                                        Command="{ReflectionBinding #Root.DataContext.RemoveLocalResourceCommand}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="{ReflectionBinding #Root.DataContext.RemoveResourceLabel}" />
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="20">
                    <Border Classes="surfaceCard" Padding="{DynamicResource CardInnerPadding}">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="sectionEyebrow" Text="{Binding CurrentTargetLabel}" />
                            <ComboBox Classes="languagePicker"
                                      ItemsSource="{Binding AvailableInstances}"
                                      SelectedItem="{Binding SelectedInstance}" />
                            <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding CurrentInstanceName}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       Text="{Binding CurrentInstanceVersionSummary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       Text="{Binding CurrentTargetPath}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Classes="surfaceCard" Padding="{DynamicResource CardInnerPadding}">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="sectionEyebrow" Text="{Binding ActivityLabel}" />
                            <TextBlock FontSize="22" FontWeight="Bold" Text="{Binding ActivityMessage}" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ActivityProgress}" Height="10" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.RowSpan="3"
                Background="#66000000"
                IsVisible="{Binding IsGameInstallPanelOpen}">
            <Grid>
                <Border Classes="surfaceCard"
                        Width="720"
                        MaxWidth="720"
                        Padding="{DynamicResource CardInnerPadding}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="sectionEyebrow" Text="{Binding InstallPanelTitle}" />
                            <TextBlock FontSize="28" FontWeight="Black" Text="{Binding ConfirmInstallLabel}" />
                            <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                       Text="{Binding InstallPanelSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <Border Classes="softCard" Padding="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="sectionEyebrow" Text="{Binding InstanceLabel}" />
                                    <TextBlock FontSize="20" FontWeight="Bold" Text="{Binding CurrentInstanceName}" />
                                    <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                               Text="{Binding CurrentInstanceVersionSummary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Classes="softCard" Padding="16">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="sectionEyebrow" Text="{Binding GameVersionLabel}" />
                                    <TextBlock FontSize="20" FontWeight="Bold"
                                               Text="{Binding SelectedGameVersionDisplay}" />
                                    <TextBlock Foreground="{StaticResource MutedInkBrush}"
                                               Text="{Binding SelectedGameReleaseTimeDisplay}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="220,220,*" ColumnSpacing="12">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding LoaderKindLabel}" />
                                <ComboBox Classes="languagePicker"
                                          ItemsSource="{Binding GameInstallOptions}"
                                          SelectedItem="{Binding SelectedGameInstallOption}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6" IsVisible="{Binding IsGameInstallLoaderVisible}">
                                <TextBlock Text="{Binding InstallPanelLoaderSourceLabel}" />
                                <ComboBox Classes="languagePicker"
                                          ItemsSource="{Binding Sources}"
                                          SelectedItem="{Binding SelectedLoaderSource}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="6" IsVisible="{Binding IsGameInstallLoaderVisible}">
                                <TextBlock Text="{Binding LoaderVersionLabel}" />
                                <ComboBox Classes="languagePicker"
                                          ItemsSource="{Binding AvailableLoaderVersions}"
                                          SelectedItem="{Binding SelectedLoaderVersion}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                            <Button Classes="secondaryButton"
                                    Command="{Binding CloseGameInstallPanelCommand}"
                                    Content="{Binding CancelInstallLabel}" />
                            <Button Classes="secondaryButton"
                                    Command="{Binding ConfirmGameInstallCommand}"
                                    Content="{Binding ConfirmInstallLabel}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
